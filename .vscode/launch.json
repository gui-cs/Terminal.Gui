    "version": "0.2.0",
    "configurations": [
        {
            "name": ".NET Core Launch (Console - External Terminal)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/Examples/UICatalog/bin/Debug/net10.0/UICatalog.dll",
            "args": [],
            "cwd": "${workspaceFolder}/Examples/UICatalog",
            "console": "externalTerminal",
            "stopAtEntry": false
        },
        {
            "name": ".NET Core Launch (Console - Integrated Terminal)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/Examples/UICatalog/bin/Debug/net10.0/UICatalog.dll",
            "args": [],
            "cwd": "${workspaceFolder}/Examples/UICatalog",
            "console": "integratedTerminal",
            "stopAtEntry": false
        }
    ]
}