          \u001b[K\u001b[m\u001b[4mв–Ҳ\u001b[24mв”Ҡв”Ҡ\u001b[38;2;86;156;214m\u001b[48;2;30;30;30m\u001b[1mcsharp\u001b[39m\u001b[22m code block with syntax highlighting:                                  \u001b[K\u001b[mв–‘в”Ҡв”Ҡ\u001b[48;2;30;30;30m                                                                             \u001b[K\u001b[mв–‘в”Ҡв”Ҡ\u001b[38;2;156;220;254m\u001b[48;2;82;82;82mConsole\u001b[38;2;212;212;212m.\u001b[38;2;220;220;170mWriteLine\u001b[38;2;255;255;255m\u001b[1m \u001b[38;2;212;212;212m\u001b[22m(\u001b[38;2;206;145;120m\"Hello, Terminal.Gui! рҹҢҚ\"\u001b[38;2;212;212;212m);                               \u001b[K\u001b[mв–‘в”Ҡв”Ҡ\u001b[38;2;78;201;176m\u001b[48;2;82;82;82mvar\u001b[38;2;255;255;255m\u001b[1m \u001b[38;2;156;220;254m\u001b[22mx\u001b[38;2;255;255;255m\u001b[1m \u001b[38;2;212;212;212m\u001b[22m=\u001b[38;2;255;255;255m\u001b[1m \u001b[38;2;181;206;168m\u001b[22m42\u001b[38;2;212;212;212m;                                                                  \u001b[K\u001b[mв–‘в”Ҡв”Ҡ\u001b[48;2;30;30;30m                                                                             \u001b[K\u001b[mв–‘в”Ҡв”Ҡ\u001b[38;2;86;156;214m\u001b[48;2;30;30;30m\u001b[1mmarkdown\u001b[39m\u001b[22m code block illustrating nested markdown:                            \u001b[K\u001b[mв–‘в”Ҡв”Ҡ\u001b[48;2;30;30;30m                                                                             \u001b[K\u001b[mв–‘в”Ҡв”Ҡ\u001b[38;2;212;212;212m\u001b[48;2;82;82;82m#\u001b[38;2;255;255;255m\u001b[1m Heading 1\u001b[22m                                                                  \u001b[K\u001b[mв–‘в”Ҡв”Ҡ\u001b[38;2;255;255;255m\u001b[48;2;82;82;82m                                                                             \u001b[K\u001b[mв–‘в”Ҡв”Ҡ\u001b[38;2;255;255;255m\u001b[48;2;82;82;82m\u001b[1mPlain text. \u001b[38;2;212;212;212m\u001b[22m*\u001b[38;2;255;255;255m\u001b[1mFormatted text\u001b[38;2;212;212;212m\u001b[22m*\u001b[38;2;255;255;255m\u001b[1m with \u001b[38;2;212;212;212m\u001b[22m**\u001b[38;2;255;255;255m\u001b[1mbold\u001b[38;2;212;212;212m\u001b[22m**\u001b[38;2;255;255;255m\u001b[1m and \u001b[38;2;212;212;212m\u001b[22m`\u001b[38;2;255;255;255m\u001b[1minline code\u001b[38;2;212;212;212m\u001b[22m`\u001b[38;2;255;255;255m\u001b[1m.\u001b[22m                \u001b[K\u001b[mв–јв”Ҡв””в”„в”„в”„в”„в”„в”„в”„в”„в”„в”„в”„в”„в”„в”„в”„в”„в”„в”„в”„в”„в”„в”„в”„в”„в”„в”„в”„в”„в”„в”„в”„в”„в”„в”„в”„в”„в”„в”„в”„в”„в”„в”„в”„в”„в”„в”„в”„в”„в”„в”„в”„в”„в”„в”„в”„в”„в”„в”„в”„в”„в”„в”„в”„в”„в”„в”„в”„в”„в”„в”„в”„в”„в”„в”„в”„в”„в”„в”„в”ҳ"]
