<?xml version="1.0" encoding="utf-8"?>
<RunSettings>
	<!-- Code Coverage Config -->
	<DataCollectionRunSettings>
		<DataCollectors>
			<DataCollector friendlyName="XPlat Code Coverage">
				<Configuration>
					<Format>cobertura</Format>
					<ExcludeByFile>**/obj/**/*.*</ExcludeByFile>
					<Exclude>[*]*.g.cs</Exclude>
					<Exclude>[*]*AssemblyInfo.cs</Exclude>
					<!-- Exclude test projects -->
					<Exclude>[UnitTests]*</Exclude>
					<Exclude>[UnitTests.Parallelizable]*</Exclude>
					<Exclude>[IntegrationTests]*</Exclude>
					<Exclude>[TerminalGuiFluentTesting]*</Exclude>
					<!-- Exclude analyzers and UI catalog -->
					<Exclude>[Terminal.Gui.Analyzers]*</Exclude>
					<Exclude>[UICatalog]*</Exclude>
				</Configuration>
			</DataCollector>
		</DataCollectors>
	</DataCollectionRunSettings>

	<!-- xUnit Config for Stop-on-Fail -->
	<xUnit>
		<ParallelizeAssembly>false</ParallelizeAssembly>
		<ParallelizeTestCollections>false</ParallelizeTestCollections>
		<MaxParallelThreads>1</MaxParallelThreads>
		<StopOnFail>true</StopOnFail>
	</xUnit>

	<RunConfiguration>
		<ResultsDirectory>../TestResults</ResultsDirectory>
	</RunConfiguration>
</RunSettings>